{
  "name": "roderuda",
  "version": "3.4.3",
  "description": "Console for Mobile Browsers (RodEruda fork)",
  "main": "roderuda.js",
  "browserslist": [
    "since 2015",
    "not dead"
  ],
  "scripts": {
    "ci": "npm run lint && npm run test && npm run build",
    "build": "node build/clean.js && tsdown && node build/build.js",
    "build:min": "node build/clean.js && tsdown --minify && node build/build.js",
    "build:dev": "node build/clean.js && cross-env NODE_ENV=development tsdown && node build/build.js",
    "typecheck": "tsc --noEmit",
    "test": "karma start",
    "format": "lsla prettier \"*.{js,ts}\" \"src/**/*.{js,scss,css,json}\" \"build/*.js\" \"test/*.{js,html}\" --write",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "clean": "node build/clean.js",
    "setup": "lsla shx mkdir -p test/lib && lsla shx cp node_modules/jasmine-core/lib/jasmine-core/{jasmine.css,jasmine.js,jasmine-html.js,boot.js} test/lib && lsla shx cp node_modules/jasmine-jquery/lib/jasmine-jquery.js test/lib && lsla shx cp node_modules/jquery/dist/jquery.js test/lib",
    "genIcon": "lsla genIcon --input src/style/ --output src/style/icon.css --name roderuda-icon --source src/style/icon/ && lsla prettier src/**/*.css --write"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oirodolfo/eruda-console-browser.git"
  },
  "keywords": [
    "console",
    "mobile",
    "debug"
  ],
  "author": "redhoodsu",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/oirodolfo/eruda-console-browser/issues"
  },
  "homepage": "https://oirodolfo.github.io/eruda-console-browser/roderuda",
  "devDependencies": {
    "@babel/core": "^7.18.6",
    "@babel/eslint-parser": "^7.26.10",
    "@babel/plugin-proposal-class-properties": "^7.18.6",
    "@babel/plugin-transform-runtime": "^7.18.6",
    "@babel/preset-env": "^7.18.6",
    "@babel/runtime": "^7.18.6",
    "@eslint/js": "^9.22.0",
    "@jsdevtools/coverage-istanbul-loader": "^3.0.5",
    "@rollup/plugin-replace": "^6.0.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^8.2.5",
    "chobitsu": "^1.8.4",
    "core-js": "^3.37.1",
    "cross-env": "^7.0.3",
    "css-loader": "^3.4.2",
    "eslint": "^9.22.0",
    "eslint-webpack-plugin": "^5.0.0",
    "globals": "^16.0.0",
    "jasmine-core": "^2.99.1",
    "jasmine-jquery": "^2.1.1",
    "jquery": "^3.4.1",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.1.0",
    "karma-coverage-istanbul-reporter": "^2.1.1",
    "karma-jasmine": "^1.1.2",
    "karma-jquery": "^0.2.4",
    "karma-sourcemap-loader": "^0.3.7",
    "karma-webpack": "^5.0.0",
    "licia": "^1.44.0",
    "luna-box-model": "^1.0.1",
    "luna-console": "^1.3.6",
    "luna-data-grid": "^1.6.4",
    "luna-dom-viewer": "^1.8.3",
    "luna-modal": "^1.3.1",
    "luna-notification": "^0.3.3",
    "luna-object-viewer": "^0.3.2",
    "luna-setting": "^2.0.2",
    "luna-tab": "^0.4.3",
    "luna-text-viewer": "^0.2.1",
    "postcss": "^8.5.15",
    "postcss-clean": "^1.2.2",
    "postcss-loader": "^3.0.0",
    "postcss-prefixer": "^2.1.3",
    "raw-loader": "^4.0.2",
    "sass": "^1.77.6",
    "sass-loader": "^14.2.1",
    "tsdown": "^0.12.9",
    "typescript": "^5.9.3",
    "webpack": "^5.92.1",
    "webpack-bundle-analyzer": "^4.7.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.0.4"
  }
}
