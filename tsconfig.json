{
  "compilerOptions": {
    "target": "ES2015",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["DOM", "ES2015", "ES2020"],
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "declaration": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": "."
  },
  "include": [
    "src/**/*.ts",
    "roderuda.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "test"
  ]
}
